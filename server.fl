;; ═══════════════════════════════════════════════════════════
;;  DB 초기화
;; ═══════════════════════════════════════════════════════════
(define DB (db-open DB_PATH))

(db-exec DB "CREATE TABLE IF NOT EXISTS users (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  username TEXT UNIQUE NOT NULL,
  email TEXT UNIQUE NOT NULL,
  password_hash TEXT NOT NULL,
  role TEXT DEFAULT 'subscriber',
  display_name TEXT,
  bio TEXT,
  created_at INTEGER DEFAULT (strftime('%s','now'))
)" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS posts (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  title TEXT NOT NULL,
  slug TEXT UNIQUE,
  content TEXT,
  blocks TEXT,
  excerpt TEXT,
  status TEXT DEFAULT 'draft',
  post_type TEXT DEFAULT 'post',
  author_id INTEGER,
  category_id INTEGER,
  featured_image TEXT,
  view_count INTEGER DEFAULT 0,
  created_at INTEGER DEFAULT (strftime('%s','now')),
  updated_at INTEGER DEFAULT (strftime('%s','now'))
)" (list))
(db-exec DB "ALTER TABLE posts ADD COLUMN blocks TEXT" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS categories (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT NOT NULL,
  slug TEXT UNIQUE,
  description TEXT,
  parent_id INTEGER DEFAULT 0,
  post_count INTEGER DEFAULT 0
)" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS tags (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT UNIQUE NOT NULL,
  slug TEXT UNIQUE
)" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS post_tags (
  post_id INTEGER,
  tag_id INTEGER,
  PRIMARY KEY(post_id, tag_id)
)" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS comments (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  post_id INTEGER,
  author TEXT NOT NULL,
  email TEXT,
  content TEXT NOT NULL,
  status TEXT DEFAULT 'pending',
  parent_id INTEGER DEFAULT 0,
  created_at INTEGER DEFAULT (strftime('%s','now'))
)" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS media (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  filename TEXT NOT NULL,
  original_name TEXT,
  mime_type TEXT,
  file_size INTEGER,
  url TEXT,
  alt_text TEXT,
  created_at INTEGER DEFAULT (strftime('%s','now'))
)" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS options (
  option_key TEXT PRIMARY KEY,
  option_value TEXT
)" (list))

(db-exec DB "CREATE TABLE IF NOT EXISTS sessions (
  token TEXT PRIMARY KEY,
  user_id INTEGER,
  expires_at INTEGER
)" (list))

