;; fl-press — FreeLang fx2 CMS (WordPress 호환 메뉴/기능)
(load "./fx-std.fl")

;; fx2에서 req-param은 동작 안 함 → 직접 params 맵 접근
(defn rp [$req $key]
  (get (get $req "params") $key))

(define PORT    40814)
(define DB_PATH "/home/kimjin/kim/Desktop/kim/01_Active_Projects/fl-press/flpress.db")
(define UPLOAD_DIR "/home/kimjin/kim/Desktop/kim/01_Active_Projects/fl-press/app/uploads")
